#!/bin/bash -l

# Set SCC project
#$ -P llamagrp

# Specify hard time limit for the job.
#   The job will be aborted if it runs longer than this time.
#   The default time is 12 hours
#$ -l h_rt=12:00:00

# Send an email when the job finishes or if it is aborted (by default no email is sent).
####$ -m ea

# Give job a name
#$ -N eval_noop_gemma2b

# Combine output and error files into a single file
#$ -j y
#$ -o log

# request 6 cores, each with 6 GB RAM at least
#$ -pe omp 4
###$ -l mem_per_core=6G

# request 1 GPU
#$ -l gpus=1
#$ -l gpu_c=8.5
#$ -l gpu_memory=47G

# Submit an array job with 5 tasks
#$ -t 1

# Keep track of information related to the current job
echo "=========================================================="
echo "Start date : $(date)"
echo "Job name : $JOB_NAME"
echo "Job ID : $JOB_ID  $SGE_TASK_ID"
echo "=========================================================="
nvidia-smi


module load cuda/11.8
module load torch/2.1
module load miniconda/23.11.0
conda activate <your_env>

# API keys and caching dirs
export HF_HOME="<your hf home>"
export HF_TOKEN="<your hf token>"
ROOT=$(pwd)
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True


MODEL="google/gemma-2-2b"
MODEL_NAME="gemma-2-2b"

cd nnsight_patching_experiment

# top 10 heads
#Value fetcher heads: [[22, 5], [18, 6], [22, 4], [19, 1], [20, 3], [23, 6], [16, 4], [22, 2], [15, 7], [25, 4]]
#Position transmitter heads: [[15, 7], [16, 4], [17, 7], [17, 3], [14, 4], [13, 6], [16, 6], [16, 7], [12, 3], [17, 5]]
#Position detector heads: [[12, 3], [14, 4], [8, 1], [10, 5], [12, 0], [5, 4], [13, 6], [11, 5], [8, 0], [6, 0]]
#Structure reader heads: [[11, 5], [7, 7], [7, 1], [11, 2], [11, 4], [7, 3], [10, 3], [9, 3], [9, 2], [11, 0]]


python eval_circuits.py \
  --model $MODEL \
  --datafile "${ROOT}/data/boxes_altAlways_default_maxop12_5k/train-t5.jsonl" \
  --batch_size 8 \
  --num_samples 100 \
  --ops_order "" \
  --query_ops_order "" \
  --counterfactual "rand_obj_rand_query_id" \
  --circuit_root_path "${ROOT}/outputs/nnsight_patch_noop/${MODEL_NAME}/n200" \
#  --n_groupA 30 \
#  --n_groupB 10 \
#  --n_groupC 10 \
#  --n_groupD 10


